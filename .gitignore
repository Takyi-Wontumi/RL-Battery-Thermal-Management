cat > .gitignore <<'EOF'
# Python virtual environments
.venv/
venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter / notebooks
.ipynb_checkpoints/

# OS / editor junk
.DS_Store
.vscode/
.idea/

# Logs
logs/
*.log

# RL models and checkpoints
models/
*.zip
*.pkl

# Generated outputs
outputs/
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.csv

# TensorBoard
events.out.tfevents.*

# Build/package artifacts
build/
dist/
*.egg-info/

# Environment files
.env
.env.*
EOF